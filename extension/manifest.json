{
  "manifest_version": 3,
  "name": "Recruitimation",
  "version": "1.0.0",
  "description": "Ingest candidates from Indeed and LinkedIn into Recruitimation",
  "permissions": ["storage", "activeTab", "scripting", "tabs"],
  "host_permissions": [
    "https://employers.indeed.com/*",
    "https://www.linkedin.com/talent/*",
    "https://www.linkedin.com/hiring/*",
    "http://localhost:3000/*",
    "https://backend-production-a0d3.up.railway.app/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://employers.indeed.com/*"],
      "js": ["content/indeed.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://employers.indeed.com/candidates*"],
      "js": ["content/indeed_candidates.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://employers.indeed.com/*/applicants/*",
        "https://employers.indeed.com/candidates*"
      ],
      "js": ["content/indeed_profile.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.linkedin.com/talent/*",
        "https://www.linkedin.com/hiring/*"
      ],
      "js": ["content/linkedin.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["interceptor.js"],
      "matches": ["https://www.linkedin.com/*"]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Recruitimation"
  }
}
